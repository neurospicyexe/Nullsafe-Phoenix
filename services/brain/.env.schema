# Phoenix Brain — environment schema (multi-provider LLM swarm orchestration)
# @defaultSensitive=true @defaultRequired=false
#
# On the VPS the values live in `.env.brain` (gitignored). This is the densest
# secret cluster in the suite: provider keys live ONLY here. Only INFERENCE_ENABLED
# is truly required; every API key is required only when INFERENCE_ENABLED=true.

# --- Provider API keys (the secret cluster) ---

# DeepSeek V3 — primary inference + routing.
# @type=string @sensitive
DEEPSEEK_API_KEY=

# Anthropic Claude.
# @type=string @sensitive
ANTHROPIC_API_KEY=

# OpenAI GPT.
# @type=string @sensitive
OPENAI_API_KEY=

# Moonshot Kimi (platform.moonshot.ai — note: .cn endpoint pairs with .cn key).
# @type=string @sensitive
KIMI_API_KEY=

# Groq (Llama inference).
# @type=string @sensitive
GROQ_API_KEY=

# Mistral (incl. Voxtral voice models).
# @type=string @sensitive
MISTRAL_API_KEY=

# Shared secret for Halseth D1 API auth (Halseth's ADMIN_SECRET, by this name here).
# @type=string @sensitive
HALSETH_ADMIN_SECRET=

# --- Non-secret URLs ---

# @type=url @sensitive=false
LOCAL_INFERENCE_URL=

# LM Studio reverse-SSH tunnel (preferred over LOCAL_INFERENCE_URL).
# @type=url @sensitive=false
LMSTUDIO_URL=

# @type=url @sensitive=false
OLLAMA_URL=

# Halseth Worker URL (echo metrics, identity kernel). Brain treats Halseth as WebMind.
# @type=url @sensitive=false
HALSETH_URL=

# Phoenix WebMind URL (continuity state). Default http://127.0.0.1:8002.
# @type=url @sensitive=false
WEBMIND_URL=

# CORS allowed origin (typically the Relay URL). Default http://127.0.0.1:8000.
# @type=url @sensitive=false
BRAIN_ALLOWED_ORIGIN=

# --- Paths / host ---

# Directory of companion identity YAML files. Default ./services/brain/identity/data.
# @type=string @sensitive=false
IDENTITY_DIR=

# Obsidian vault path (future write tool).
# @type=string @sensitive=false
OBSIDIAN_VAULT_PATH=

# FastAPI host binding (127.0.0.1 = local only; 0.0.0.0 = all). Default 127.0.0.1.
# @type=string @sensitive=false
BRAIN_HOST=

# --- Toggles ---

# Enable LLM inference. Default false.
# @type=boolean @sensitive=false @required
INFERENCE_ENABLED=

# Enable synthesis loop (periodic orientation generation). Default false.
# @type=boolean @sensitive=false
SYNTHESIS_ENABLED=

# Enable multi-companion swarm inference. Default false.
# @type=boolean @sensitive=false
SWARM_MODE=

# Structural anti-loop on turn shape. Default true.
# @type=boolean @sensitive=false
PROGRESS_BRAKE=

# --- Models (per-companion overrides fall back to DEEPSEEK_MODEL) ---

# @type=string @sensitive=false
DEEPSEEK_MODEL=

# @type=string @sensitive=false
ROUTING_MODEL=

# @type=string @sensitive=false
CYPHER_MODEL=

# @type=string @sensitive=false
DREVAN_MODEL=

# @type=string @sensitive=false
GAIA_MODEL=

# --- Sampling temperatures / top-p (0-2 / 0-1) ---

# @type=number @sensitive=false
INFERENCE_TEMPERATURE=

# Routing classifier temperature (lower = more deterministic). Default 0.3.
# @type=number @sensitive=false
ROUTING_TEMPERATURE=

# @type=number @sensitive=false
CYPHER_TEMPERATURE=

# @type=number @sensitive=false
DREVAN_TEMPERATURE=

# @type=number @sensitive=false
GAIA_TEMPERATURE=

# @type=number @sensitive=false
CYPHER_TOP_P=

# @type=number @sensitive=false
DREVAN_TOP_P=

# @type=number @sensitive=false
GAIA_TOP_P=

# --- Swarm depth / cache / timeouts ---

# @type=number @sensitive=false
LOCAL_INFERENCE_TIMEOUT=

# @type=number @sensitive=false
MODEL_CACHE_TTL_S=

# @type=number @sensitive=false
MAX_SWARM_DEPTH=

# Depth at which companions prefer silence (self-selection taper). Default 2.
# @type=number @sensitive=false
DEPTH_BIAS_THRESHOLD=

# Cosine similarity threshold for lexical echo detection (0-1). Default 0.38.
# @type=number @sensitive=false
SWARM_ECHO_THRESHOLD=

# Synthesis loop interval (seconds). Default 1200.
# @type=number @sensitive=false
SYNTHESIS_INTERVAL=

# --- Progress-brake tuning ---

# @type=number @sensitive=false
BRAKE_SOLO_DEPTH=

# @type=number @sensitive=false
BRAKE_PAIR_DEPTH=

# Consecutive companion-only turns before floor hands back to Raziel. Default 4.
# @type=number @sensitive=false
BRAKE_HANDBACK_TURNS=

# Channel echo-pressure warn threshold (0-1 cosine). Default 0.66.
# @type=number @sensitive=false
BRAKE_PRESSURE_WARN=

# Channel echo-pressure critical threshold (0-1). Default 0.82.
# @type=number @sensitive=false
BRAKE_PRESSURE_RED=

# Echo-pressure cache TTL (seconds). Default 90.
# @type=number @sensitive=false
BRAKE_PRESSURE_TTL_S=

# Comma-separated Discord channel IDs exempt from floor-handback (pure inter-companion).
# @type=string @sensitive=false
BRAKE_HANDBACK_EXEMPT_CHANNELS=
