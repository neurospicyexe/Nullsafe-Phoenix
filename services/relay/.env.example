# Relay Service - Phoenix v2 Environment Configuration
# Copy this file to .env and fill in your actual values

# ==============================================================================
# BRAIN SERVICE CONNECTION (REQUIRED)
# ==============================================================================

# URL of the Brain service
# Default: http://localhost:8001 (for local development)
# Production: URL of your workstation Brain service (with proper networking/tunneling)
BRAIN_SERVICE_URL=http://localhost:8001

# ==============================================================================
# REDIS CONNECTION (REQUIRED)
# ==============================================================================

# Redis connection URL for queue management
# Default: redis://localhost:6379
# Production: Your Redis server URL (should be on same VPS as Relay)
REDIS_URL=redis://localhost:6379

# ==============================================================================
# PERFORMANCE TUNING (OPTIONAL)
# ==============================================================================

# Fast path timeout (seconds) - how long to wait for Brain on immediate requests
# Default: 5
#BRAIN_TIMEOUT_FAST=5

# Drainer timeout (seconds) - how long drainer waits for Brain when processing queue
# Default: 30
#BRAIN_TIMEOUT_DRAINER=30

# Drainer interval (seconds) - how often drainer checks queue
# Default: 2
#DRAINER_INTERVAL=2

# Max retries before moving to dead letter queue
# Default: 5
#MAX_RETRIES=5

# Deduplication TTL (seconds) - how long to remember processed packets
# Default: 86400 (24 hours)
#DEDUPE_TTL=86400

# ==============================================================================
# NOTES
# ==============================================================================
#
# The Relay service is the always-on buffering layer that:
# 1. Receives ThoughtPackets from Discord Bot
# 2. Attempts fast path to Brain (5s timeout)
# 3. Falls back to durable Redis queue if Brain is offline
# 4. Runs background drainer to process queue when Brain comes online
# 5. Emits AgentReplies to per-agent outboxes for Discord Bot consumption
#
# The Relay service does NOT:
# - Talk to Discord (that's Discord Bot's job)
# - Call LLM APIs (that's Brain's job)
# - Load agent identities (that's Brain's job)
#
# Deployment:
# - Typically runs on VPS (always online)
# - Redis should be on same VPS for low latency
# - Brain service may be on different machine (workstation) and go offline
#
# Queue Management:
# - Incoming queue: phx:queue:incoming
# - Inflight queue: phx:queue:inflight
# - Dead letter: phx:queue:deadletter
# - Per-agent outboxes:
#   - phx:outbox:discord:drevan
#   - phx:outbox:discord:cypher
#   - phx:outbox:discord:gaia
#
# Performance Tuning:
# - BRAIN_TIMEOUT_FAST: 5s (default, hardcoded in config.py)
# - BRAIN_TIMEOUT_DRAINER: 30s (default, hardcoded in config.py)
# - DRAINER_INTERVAL: 2s (default, hardcoded in config.py)
# - MAX_RETRIES: 5 (default, hardcoded in config.py)
