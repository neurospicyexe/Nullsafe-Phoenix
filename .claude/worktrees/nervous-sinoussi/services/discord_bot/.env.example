# Discord Bot Service - Phoenix v2 Environment Configuration
# Copy this file to .env and fill in your actual values

# ==============================================================================
# DISCORD CONFIGURATION (REQUIRED)
# ==============================================================================

# Your Discord bot token from Discord Developer Portal
# Get this from: https://discord.com/developers/applications
# Each agent (Drevan, Cypher, Gaia) needs its own bot token
DISCORD_TOKEN=your_discord_bot_token_here

# ==============================================================================
# RELAY SERVICE CONNECTION (REQUIRED)
# ==============================================================================

# URL of the Relay service
# Default: http://localhost:8000 (for local development)
# Production: URL of your VPS Relay service
RELAY_API_URL=http://localhost:8000

# ==============================================================================
# REDIS CONNECTION (REQUIRED)
# ==============================================================================

# Redis connection URL for outbox queue consumption
# Default: redis://localhost:6379
# Production: Your Redis server URL
REDIS_URL=redis://localhost:6379

# ==============================================================================
# NOTES
# ==============================================================================
#
# This service ONLY handles Discord communication. It should NOT contain:
# - AI API keys (those belong in Brain service)
# - Database credentials (Phoenix v2 has no database)
# - Obsidian paths (those belong in Brain service)
#
# The Discord Bot's job is to:
# 1. Receive messages from Discord
# 2. Send ThoughtPackets to Relay
# 3. Consume outbox and send replies back to Discord
#
# For running multiple agents simultaneously, create separate .env files:
# - .env.drevan
# - .env.cypher
# - .env.gaia
#
# Then start each bot with: python bot.py (after loading the correct .env)
