# Brain Service - Phoenix v2 Environment Configuration
# Copy this file to .env and fill in your actual values

# ==============================================================================
# INFERENCE CONTROL (REQUIRED)
# ==============================================================================

# Enable LLM inference (true/false)
# Set to false for Phase 1 stub replies
# When true, requires ANTHROPIC_API_KEY or OPENAI_API_KEY to be set
INFERENCE_ENABLED=false

# ==============================================================================
# OBSIDIAN INTEGRATION (OPTIONAL - for future write tool)
# ==============================================================================

# Path to your Obsidian vault for note writing
# Example: C:\Users\YourName\Documents\ObsidianVault
# Example: /home/user/Documents/ObsidianVault
OBSIDIAN_VAULT_PATH=C:\Users\YourName\OneDrive\Desktop\Obsidian

# ==============================================================================
# AGENT IDENTITY CONFIGURATION (OPTIONAL)
# ==============================================================================

# Directory containing agent identity YAML files
# Default: ./services/brain/identity/data
# Only set this if you want to use a custom identity directory
IDENTITY_DIR=./services/brain/identity/data

# ==============================================================================
# AI API KEYS (REQUIRED - when LLM inference is implemented)
# ==============================================================================

# Anthropic API Key (for Claude models)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-your_anthropic_api_key_here

# OpenAI API Key (for GPT models)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your_openai_api_key_here

# OpenAI Organization ID (optional)
OPENAI_ORG_ID=your_org_id_here

# LM Studio Configuration (for local models)
# Only needed if using LM Studio for local LLM inference
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_API_KEY=lm-studio

# ==============================================================================
# MODEL RESTRICTIONS (OPTIONAL)
# ==============================================================================

# Comma-separated list of allowed OpenAI models
ALLOWED_OPENAI_MODELS=gpt-4o,gpt-4o-mini,gpt-4-turbo

# Comma-separated list of blocked OpenAI models
BLOCKED_OPENAI_MODELS=gpt-4-32k

# Comma-separated list of allowed Anthropic models
ALLOWED_ANTHROPIC_MODELS=claude-3-5-sonnet-20241022,claude-3-5-haiku-20241022

# Comma-separated list of blocked Anthropic models
BLOCKED_ANTHROPIC_MODELS=claude-2.1

# ==============================================================================
# WEB SEARCH (OPTIONAL - for future web search tool)
# ==============================================================================

# SerpAPI Key for web search functionality
# Get from: https://serpapi.com/
SERPAPI_API_KEY=your_serpapi_key_here

# Monthly search limit
WEB_SEARCH_MONTHLY_LIMIT=250

# ==============================================================================
# NOTES
# ==============================================================================
#
# The Brain service is the ONLY service that:
# - Calls LLM APIs (Anthropic, OpenAI, LM Studio)
# - Loads agent identities from YAML files
# - Performs agent intelligence and decision-making
# - Executes tools (Obsidian write, web search, etc.)
#
# The Brain service does NOT:
# - Talk to Discord (that's Discord Bot's job)
# - Use Redis (it's stateless HTTP)
# - Handle queueing (that's Relay's job)
#
# Day One Status:
# - Currently returns stub replies (no actual LLM calls yet)
# - AI API keys are optional until LLM inference is implemented
# - Obsidian write tool and web search are not yet implemented
